    "# ============================================================\n",
    "# Efekti Domino sipas Diteve (+1, +2, +3)\n",
    "# ============================================================\n",
    "\n",
    "\n",
    "aktiv = (dom.conflict>0)|(dom.attention>dom.attention.median())|(dom.neg_tone>dom.neg_tone.median())\n",
    "vals  = [dom[aktiv][f\"nb_c{l}\"].mean()*100 for l in [1,2,3]]\n",
