    "          avg_articles=(\"NumArticles\", \"mean\"),\n",
    "          avg_attention=(\"attention_score\", \"mean\"),\n",
    "          conflict_share=(\"is_conflict\", \"mean\")\n",
    "      )\n",
    "      .reset_index()\n",
    "      .sort_values(\"avg_attention\", ascending=False)\n",
    ")\n",
    "\n",
    "category_stats"
